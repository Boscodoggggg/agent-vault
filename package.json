{
  "name": "agent-vault",
  "version": "0.1.0",
  "description": "Local-first continuity vault for Codex, Claude Code, and other AI agent sessions.",
  "type": "module",
  "main": "out/main/index.js",
  "author": "Boscodoggggg",
  "license": "MIT",
  "homepage": "https://github.com/Boscodoggggg/agent-vault#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Boscodoggggg/agent-vault.git"
  },
  "bugs": {
    "url": "https://github.com/Boscodoggggg/agent-vault/issues"
  },
  "keywords": [
    "codex",
    "claude-code",
    "electron",
    "ai-agents",
    "session-history",
    "local-first",
    "continuation-pack"
  ],
  "scripts": {
    "dev": "electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "preview": "electron-vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier --write .",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder"
  },
  "dependencies": {
    "@ant-design/icons": "^6.3.2",
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "antd": "^6.5.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@typescript-eslint/eslint-plugin": "^8.18.2",
    "@typescript-eslint/parser": "^8.18.2",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.2.1",
    "electron-builder": "^26.15.3",
    "electron-vite": "^2.3.0",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^5.1.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "vite": "^8.1.4",
    "vitest": "^2.1.8"
  },
  "build": {
    "appId": "dev.agentvault.app",
    "productName": "Agent Vault",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "package.json",
      "README.md",
      "LICENSE"
    ],
    "mac": {
      "category": "public.app-category.developer-tools"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage",
      "category": "Development"
    }
  }
}
